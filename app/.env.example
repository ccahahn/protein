# Required — Claude Sonnet for all four agents.
ANTHROPIC_API_KEY=

# Required — Braintrust is the source of truth for prompts AND the trace log.
# Without this the agents cannot load their system prompts.
BRAINTRUST_API_KEY=

# Optional but recommended on Vercel. Braintrust's SDK caches prompts and
# parameters on disk; by default it writes to $HOME/.braintrust/*, which
# doesn't exist on the Vercel serverless sandbox. Point it at /tmp instead
# to silence "Failed to write to disk cache" warnings. Local dev doesn't
# need these — $HOME is writable on your laptop.
BRAINTRUST_PROMPT_CACHE_DIR=/tmp/braintrust-prompt-cache
BRAINTRUST_PARAMETERS_CACHE_DIR=/tmp/braintrust-parameters-cache
