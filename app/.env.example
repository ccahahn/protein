# Required — Claude Sonnet for all five agents.
ANTHROPIC_API_KEY=

# Required — Deepgram Nova-3 for household + pantry voice transcription.
DEEPGRAM_API_KEY=

# Required — Braintrust is the source of truth for prompts AND the trace log.
# Without this the agents cannot load their system prompts.
BRAINTRUST_API_KEY=

# Optional override — defaults to claude-sonnet-4-5. Set to claude-sonnet-4-6 if you want 4.6 explicitly.
ANTHROPIC_MODEL=claude-sonnet-4-5
